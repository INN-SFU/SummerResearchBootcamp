        "# Hands-on session\n",
        "Note: To run (execute) the code cell below, press control/command + Enter\n",
        "\n",
        "# Nuts & Bolts\n",
        "Math with Python (operators)\n",
        "Types of Operations:\n",
        "\n",
        "Addition: '+'\n",
        "Subtraction: '-'\n",
        "Multiplication: '*'\n",
        "Division: '/'\n",
        "Exponents: '**'"
